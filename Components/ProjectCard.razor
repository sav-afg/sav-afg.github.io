@using Portfolio.Models

<div class="card h-100 shadow-sm">
    @if (imagePaths.Any())
    {
        <div id="carousel-@Project.Id" class="carousel slide" >
            <div class="carousel-inner">
                @for (int i = 0; i < imagePaths.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@imagePaths[i]" class="d-block w-100" alt="@Project.Title - Screenshot @(i + 1)" style="height: 250px; object-fit: contain; background-color: #f8f9fa;">
                    </div>
                }
            </div>
            @if (imagePaths.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#carousel-@Project.Id" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carousel-@Project.Id" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            }
        </div>
    }
    <div class="card-body d-flex flex-column">
        <h5 class="card-title">@Project.Title</h5>
        <p class="card-text">@Project.Description</p>
        <p class="text-muted small"><strong>Tech:</strong> @Project.Technologies</p>
        <div class="mt-auto">
            <div class="d-flex gap-2 flex-wrap">
                @if (Project.HasWalkthrough)
                {
                    <a href="@($"/projects/walkthrough/{Project.Id}")" class="btn btn-success btn-sm">
                        <i class="bi bi-images"></i> Walkthrough
                    </a>
                }
                <a href="@($"/projects/{Project.Id}")" class="btn btn-primary btn-sm">View Details</a>
                @if (!string.IsNullOrEmpty(Project.GitHubUrl))
                {
                    <a href="@Project.GitHubUrl" target="_blank" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-github"></i> GitHub
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Project Project { get; set; } = null!;

    private List<string> imagePaths = new();

    protected override void OnInitialized()
    {
        // Collect all non-empty image paths
        imagePaths = new List<string>();
        
        if (!string.IsNullOrEmpty(Project.ImagePath1))
            imagePaths.Add(Project.ImagePath1);
        if (!string.IsNullOrEmpty(Project.ImagePath2))
            imagePaths.Add(Project.ImagePath2);
        if (!string.IsNullOrEmpty(Project.ImagePath3))
            imagePaths.Add(Project.ImagePath3);
        if (!string.IsNullOrEmpty(Project.ImagePath4))
            imagePaths.Add(Project.ImagePath4);
        if (!string.IsNullOrEmpty(Project.ImagePath5))
            imagePaths.Add(Project.ImagePath5);
        if( !string.IsNullOrEmpty(Project.ImagePath6))
            imagePaths.Add(Project.ImagePath6);
        if( !string.IsNullOrEmpty(Project.ImagePath7))
            imagePaths.Add(Project.ImagePath7);
        if( !string.IsNullOrEmpty(Project.ImagePath8))
            imagePaths.Add(Project.ImagePath8);
        if (! string.IsNullOrEmpty(Project.ImagePath9))
            imagePaths.Add(Project.ImagePath9);
    }
}
